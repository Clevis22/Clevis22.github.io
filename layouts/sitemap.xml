{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
{{- /*
  sitemap.xml — overrides Hugo's embedded sitemap template.

  One change from stock: taxonomy term pages with fewer than 2 posts are
  skipped. Those pages carry a noindex meta (see partials/head.html), and
  listing noindexed URLs in the sitemap just generates "excluded by
  noindex" noise in Search Console. Translation links are dropped —
  single-language site.
*/}}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{- range .Data.Pages }}
  {{- if and (eq .Kind "term") (lt (len .Pages) 2) }}{{ continue }}{{ end }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ safeHTML (.Lastmod.Format "2006-01-02T15:04:05-07:00") }}</lastmod>
    {{- end }}
    {{- with .Sitemap.ChangeFreq }}
    <changefreq>{{ . }}</changefreq>
    {{- end }}
    {{- if ge .Sitemap.Priority 0.0 }}
    <priority>{{ .Sitemap.Priority }}</priority>
    {{- end }}
  </url>
  {{- end }}
</urlset>
